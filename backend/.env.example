PORT=5000
MONGODB_URI=mongodb://localhost:27017/finovatrack
# Use 32+ random characters in production (see docs/SECURITY.md for rotation)
JWT_SECRET=your_super_secret_jwt_key_here_min_16_chars
AUTH_RATE_LIMIT_MAX=15
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
FRONTEND_URL=http://localhost:5173

# Solo deploy: block new sign-ups after your account exists
# ALLOW_REGISTRATION=false
# Landing page after login: /attention (Today) or /dashboard
# DEFAULT_HOME_ROUTE=/attention

# Optional SMTP for password reset and task email reminders
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# How often to check for due task email reminders (ms, default 15 min)
TASK_REMINDER_INTERVAL_MS=900000

# Optional SMTP for password reset emails (otherwise link is logged to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@finovatrack.com

# Appointment reminders (email logs to console if SMTP unset)
# REMINDER_MINUTES_BEFORE=60
# TASK_REMINDER_INTERVAL_MS=900000

# Optional SMS via Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1234567890
# REMINDER_SMS_TO=+1234567890

# Integrations (read-only)
# CRM_API_URL=https://api.example.com/crm/leads
# CRM_API_KEY=
# CRM_LABEL=Salesforce
# BANKING_API_URL=https://api.example.com/accounts/lookup
# BANKING_API_KEY=
# BANKING_LABEL=Core Banking

# AI next-action suggestions (optional; uses rules if unset)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Daily email digest (UTC hour, checked every hour)
# DAILY_DIGEST_CHECK_MS=3600000

# Web Push (PWA) — run: npm run generate-vapid
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Weekly client backup email (UTC weekday/hour, checked hourly)
# WEEKLY_BACKUP_CHECK_MS=3600000

# Optional error logging (Sentry)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
