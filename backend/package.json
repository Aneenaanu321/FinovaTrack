{
  "name": "finovatrack-backend",
  "version": "1.0.0",
  "description": "FinovaTrack backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node scripts/seed.js",
    "generate-vapid": "node scripts/generate-vapid.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src tests",
    "format": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "format:write": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "dependencies": {
    "@sentry/node": "^7.120.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  }
}
